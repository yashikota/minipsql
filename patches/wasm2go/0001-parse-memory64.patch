 }
 
+func readMemoryType(r byteReader) (MemoryType, error) {
+	flags, err := r.ReadByte()
+	if err != nil {
+		return MemoryType{}, err
+	}
+	if flags&^byte(0x07) != 0 {
+		return MemoryType{}, fmt.Errorf("memory limits: unsupported flags %#x", flags)
+	}
+	min, err := readU64(r)
+	if err != nil {
+		return MemoryType{}, err
+	}
+	memory := MemoryType{Limits: Limits{Min: min}, Is64: flags&0x04 != 0}
+	if flags&0x01 != 0 {
+		max, err := readU64(r)
+		if err != nil {
+			return MemoryType{}, err
+		}
+		memory.Limits.Max = max
+		memory.Limits.HasMax = true
+	}
+	return memory, nil
+}
