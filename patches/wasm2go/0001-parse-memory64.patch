+func TestParseMemory64(t *testing.T) {
+	// (module (memory i64 1 4)) encoded with the Memory64 limits flag.
+	payload := []byte{0x01, 0x05, 0x01, 0x04}
+	b := append(append([]byte{}, wasmHeader...), 0x05, byte(len(payload)))
+	b = append(b, payload...)
+	m, err := wasm.Parse(bytes.NewReader(b))
+	if err != nil {
+		t.Fatal(err)
+	}
+	if len(m.Memories) != 1 || !m.Memories[0].Is64 {
+		t.Fatalf("memory = %#v, want one memory64", m.Memories)
+	}
+	if m.Memories[0].Limits.Min != 1 || !m.Memories[0].Limits.HasMax || m.Memories[0].Limits.Max != 4 {
+		t.Fatalf("limits = %#v", m.Memories[0].Limits)
+	}
+}
